{
    "name": "encrypt/encrypt",
    "description": "A top-level secrets orchestrator. Not just another .env tool — this one encrypts, locks, and sets you up for secure local and team dev.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Encrypt Team"
        }
    ],
    "require": {
        "php": ">=8.0",
        "symfony/console": "^6.0",
        "symfony/process": "^6.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Encrypt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Encrypt\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/encrypt"
    ],
    "scripts": {
        "test": "phpunit",
        "encrypt": "php bin/encrypt"
    }
}
